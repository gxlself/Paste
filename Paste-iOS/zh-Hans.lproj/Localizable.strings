/* Getting Started Guide */
"ios.guide.step1.title" = "启用自定义键盘";
"ios.guide.step1.desc" = "前往 设置 → 通用 → 键盘 → 键盘 → 添加新键盘 → Paste。然后点击 Paste 并开启「允许完全访问」。";
"ios.guide.step2.title" = "允许从其他应用粘贴";
"ios.guide.step2.desc" = "为避免每次弹出「允许粘贴」提示，请前往 设置 → Paste → 从其他 App 粘贴 → 允许。";
"ios.guide.step3.title" = "使用 Pinboard 分类";
"ios.guide.step3.desc" = "使用 Pinboard 来分类管理剪贴板内容。长按任意项目并选择「固定」来分配到特定面板。左右滑动可切换面板。";
"ios.guide.step4.title" = "iCloud 同步";
"ios.guide.step4.desc" = "在设置中开启 iCloud 同步，让你的剪贴板历史在所有 Apple 设备间保持同步。";
"ios.guide.step5.title" = "滑动导航";
"ios.guide.step5.desc" = "在剪贴板视图中左右滑动，快速切换不同的 Pinboard。";

/* Help Center */
"ios.help.history.title" = "剪贴板历史如何工作？";
"ios.help.history.answer" = "当应用处于活动状态或键盘正在使用时，Paste 会自动收集你复制的内容。项目按时间排序，置顶项目显示在最前面。";
"ios.help.edit.title" = "如何编辑内容？";
"ios.help.edit.answer" = "长按任意文本项目，点击「编辑」。你可以使用富文本工具栏来应用粗体、斜体、下划线或调整字号。";
"ios.help.keyboard.title" = "如何使用键盘扩展？";
"ios.help.keyboard.answer" = "在 设置 → 通用 → 键盘 中启用 Paste 键盘。输入时切换到 Paste 键盘即可快速从剪贴板历史中粘贴内容。";
"ios.help.pinboard.title" = "如何设置 Pinboard？";
"ios.help.pinboard.answer" = "打开应用菜单（…）并点击 Pinboards 来管理面板。你可以添加、重命名、排序和删除面板。长按项目可将其固定到特定面板。";
"ios.help.icloud.title" = "如何开启 iCloud 同步？";
"ios.help.icloud.answer" = "在应用设置中开启 iCloud 同步。重启应用后生效。你的剪贴板数据将在所有设备间同步。";
"ios.help.search.title" = "如何搜索？";
"ios.help.search.answer" = "点击顶部搜索图标。你可以按内容文本、来源应用名称或任何可见文字进行搜索。";
"ios.help.privacy.title" = "隐私与安全";
"ios.help.privacy.answer" = "所有剪贴板数据都存储在本地设备上。开启 iCloud 同步后，数据通过你的个人 iCloud 账户加密同步。不进行任何分析或追踪。";
"ios.help.paste.title" = "如何避免「允许粘贴」提示？";
"ios.help.paste.answer" = "前往系统 设置 → Paste → 从其他 App 粘贴 → 允许。这样 iOS 就不会每次都询问权限。";


/* Getting Started Guide */
"ios.guide.step1.title" = "Enable Custom Keyboard";
"ios.guide.step1.desc" = "Go to Settings → General → Keyboard → Keyboards → Add New Keyboard → Paste. Then tap Paste and enable Full Access.";
"ios.guide.step2.title" = "Allow Paste from Other Apps";
"ios.guide.step2.desc" = "To avoid the \"Allow Paste\" prompt each time, go to Settings → Paste → Paste from Other Apps → Allow.";
"ios.guide.step3.title" = "Organize with Pinboards";
"ios.guide.step3.desc" = "Use Pinboards to categorize your clips. Long-press any item and choose Pin to assign it to a board. Swipe left/right to switch between boards.";
"ios.guide.step4.title" = "iCloud Sync";
"ios.guide.step4.desc" = "Enable iCloud Sync in Settings to keep your clipboard history in sync across all your Apple devices.";
"ios.guide.step5.title" = "Swipe to Navigate";
"ios.guide.step5.desc" = "Swipe left or right on the clipboard view to quickly switch between Pinboards.";

/* Help Center */
"ios.help.history.title" = "How does clipboard history work?";
"ios.help.history.answer" = "Paste automatically collects content you copy when the app is active or the keyboard is in use. Items are sorted by time with pinned items at the top.";
"ios.help.edit.title" = "How to edit content?";
"ios.help.edit.answer" = "Long-press any text item and tap Edit. You can use the rich text toolbar to apply bold, italic, underline, or adjust font size.";
"ios.help.keyboard.title" = "How to use the keyboard extension?";
"ios.help.keyboard.answer" = "Enable the Paste keyboard in Settings → General → Keyboard. When typing, switch to Paste keyboard to quickly paste from your clipboard history.";
"ios.help.pinboard.title" = "How to set up Pinboards?";
"ios.help.pinboard.answer" = "Open the app menu (…) and tap Pinboards to manage your boards. You can add, rename, reorder, and delete pinboards. Long-press items to pin them to a specific board.";
"ios.help.icloud.title" = "How to enable iCloud sync?";
"ios.help.icloud.answer" = "Go to Settings in the app and toggle on iCloud Sync. Restart the app for changes to take effect. Your clipboard data will sync across all your devices.";
"ios.help.search.title" = "How to search?";
"ios.help.search.answer" = "Tap the search icon in the top bar. You can search by content text, source app name, or any visible text.";
"ios.help.privacy.title" = "Privacy & Security";
"ios.help.privacy.answer" = "All clipboard data is stored locally on your device. When iCloud Sync is enabled, data is encrypted and synced via your personal iCloud account. No analytics or tracking is performed.";
"ios.help.paste.title" = "How to avoid the Allow Paste prompt?";
"ios.help.paste.answer" = "Go to system Settings → Paste → Paste from Other Apps → Allow. This prevents iOS from asking for permission every time.";

/* Paste Permission Guide */
"ios.pastePermission.title" = "Allow Paste from Other Apps";
"ios.pastePermission.header" = "Stop the \"Allow Paste\" prompt";
"ios.pastePermission.explanation" = "iOS asks for permission every time an app reads clipboard content from another app. You can allow Paste to read the clipboard without prompting.";
"ios.pastePermission.step1" = "Open system Settings";
"ios.pastePermission.step2" = "Scroll down and tap Paste";
"ios.pastePermission.step3" = "Tap \"Paste from Other Apps\"";
"ios.pastePermission.step4" = "Select \"Allow\"";
"ios.pastePermission.openSettings" = "Open Settings";
